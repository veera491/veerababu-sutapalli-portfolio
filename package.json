{
  "name": "veerababu-sutapalli-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate:content": "tsx --conditions=react-server scripts/validate-content.ts",
    "validate:assets": "tsx --conditions=react-server scripts/validate-assets.ts",
    "verify:project-assets": "node scripts/verify-project-assets.mjs",
    "verify:seo": "node scripts/verify-seo.mjs",
    "verify:seo:production": "node scripts/verify-seo.mjs --production",
    "build": "npm run validate:content && npm run validate:assets && npm run verify:project-assets && npm run verify:seo && next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run validate:content && npm run validate:assets && npm run verify:project-assets && npm run verify:seo && npm run lint && next build",
    "test:e2e": "playwright test",
    "check:full": "npm run check && npm run test:e2e",
    "check:production": "cross-env NEXT_PUBLIC_SITE_URL=https://portfolio.example.test npm run verify:seo:production && cross-env NEXT_PUBLIC_SITE_URL=https://portfolio.example.test npm run build && cross-env NEXT_PUBLIC_SITE_URL=https://portfolio.example.test npm run test:e2e",
    "verify:live": "node scripts/verify-live-production.mjs",
    "test:e2e:live": "cross-env LIVE_BASE_URL=https://veerababu-sutapalli.vercel.app playwright test --config=playwright.live.config.ts",
    "build:icons": "node scripts/build-icons.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "engines": {
    "node": "24.x"
  }
}
