# =============================================================================
# Veerababu Sutapalli Portfolio — Environment Variables
# =============================================================================
# Copy this file to .env.local for local overrides.
# NEVER commit .env.local or real tokens to Git.
# Set production values in the Vercel project dashboard.
# =============================================================================

# --------------------------------------------------------------------------
# REQUIRED (Production)
# --------------------------------------------------------------------------
# The canonical public URL of the site — no trailing slash.
# On Vercel, set this in Project Settings > Environment Variables.
# Production value: https://veerababu-sutapalli.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# --------------------------------------------------------------------------
# OPTIONAL — Webmaster Verification
# --------------------------------------------------------------------------
# Google Search Console (URL-prefix property for https://veerababu-sutapalli.vercel.app)
# Obtain from: https://search.google.com/search-console
# Paste the content value from the HTML tag verification method.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools (verify ownership at https://www.bing.com/webmasters)
# Paste the content value from the meta tag verification method.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --------------------------------------------------------------------------
# VERCEL AUTOMATIC VARIABLES (do not set manually)
# --------------------------------------------------------------------------
# These are injected automatically by Vercel at build time when deployed.
# VERCEL_PROJECT_PRODUCTION_URL — the canonical Vercel URL (host only, no scheme)
# VERCEL_URL                    — the deployment-specific preview URL (host only)
